{
  "env": {
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-5[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5"
  },
  "permissions": {
    "allow": ["Read(//Users/yasainet/ghq/**)"],
    "deny": [
      "Bash(dd if=/dev/*)",
      "Bash(mkfs*)",
      "Bash(diskutil eraseDisk*)",
      "Bash(diskutil partitionDisk*)",
      "Bash(supabase db reset --linked*)",
      "Edit(**/supabase/migrations/*.sql)",
      "Write(**/supabase/migrations/*.sql)",
      "mcp__supabase__apply_migration"
    ],
    "ask": ["Bash(rm:*)", "Bash(rmdir:*)", "Bash(gh pr merge:*)"],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/ghq/github.com/yasainet/dotfiles/dot-claude/hooks/inject-path-rule.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/ghq/github.com/yasainet/dotfiles/dot-claude/hooks/on-prompt.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/ghq/github.com/yasainet/dotfiles/dot-claude/hooks/on-needs-input.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/ghq/github.com/yasainet/dotfiles/dot-claude/hooks/herdr-agent-state.sh session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "fileSuggestion": {
    "type": "command",
    "command": "bash ~/ghq/github.com/yasainet/dotfiles/dot-claude/scripts/ghq-suggest.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "normal",
  "preferredNotifChannel": "ghostty",
  "inputNeededNotifEnabled": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
