{
  "env": {},
  "permissions": {
    "allow": [
      "Read(//Users/yasainet/Projects/**)",
      "Read(//Users/yasainet/Documents/**)",
      "Read(//Users/yasainet/dotfiles/**)"
    ],
    "deny": [
      "Bash(dd if=/dev/*)",
      "Bash(mkfs*)",
      "Bash(diskutil eraseDisk*)",
      "Bash(diskutil partitionDisk*)",
      "Bash(supabase db reset --linked*)",
      "Edit(**/supabase/migrations/*.sql)",
      "Write(**/supabase/migrations/*.sql)",
      "mcp__supabase__apply_migration"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch -c:*)",
      "Bash(git worktree add:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/dot-claude/hooks/inject-path-rule.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/dot-claude/hooks/on-prompt.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/dot-claude/hooks/on-notification.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/dot-claude/hooks/on-stop.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/dotfiles/dot-claude/hooks/on-needs-input.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "model": "claude-opus-4-7[1m]",
  "language": "Japanese",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "editorMode": "normal",
  "preferredNotifChannel": "notifications_disabled",
  "skipAutoPermissionPrompt": true
}
