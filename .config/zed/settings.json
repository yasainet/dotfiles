{
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night"
  },
  "experimental.theme_overrides": {
    "background.appearance": "transparent"
    // "border.variant": "#313244",
    // "scrollbar.thumb.border": "#1e1e2e"
  },
  // "file_types": {},
  "ui_font_size": 14,
  "unstable.ui_density": "compact",
  "show_user_picture": false,
  "outline_panel": {
    "button": false
  },
  "chat_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "tabs": {
    "git_status": true
  },
  "gutter": {
    "code_actions": false,
    "runnables": false
    // "folds": false
  },
  "project_panel": {
    "auto_fold_dirs": false
  },
  "buffer_font_size": 14,
  "current_line_highlight": "none",
  "scrollbar": {
    "show": "auto",
    "cursors": false,
    "git_diff": false
  },
  "soft_wrap": "editor_width",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vertical_scroll_margin": 5,
  "journal": {
    "hour_format": "hour24"
  },
  "format_on_save": "on",
  "formatter": "language_server",
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll.eslint": true
  },
  "terminal": {
    "copy_on_select": true,
    "blinking": "on",
    "button": false,
    "toolbar": {
      "title": false,
      "breadcrumbs": false
    }
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "languages": {
    "Markdown": {
      "show_inline_completions": false
    }
  },
  "show_inline_completions": true,
  "assistant": {
    "button": false,
    "version": "2",
    "default_width": 640,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-3-5-sonnet-latest"
    }
  },
  "language_models": {
    // "anthropic": {
    //   "version": "1",
    //   "low_speed_timeout_in_seconds": 600,
    //   "available_models": [
    //     {
    //       "name": "claude-3-5-sonnet-latest",
    //       "display_name": "claude-3-5-sonnet-latest",
    //       "max_tokens": 200000,
    //       "tool_override": "",
    //       "cache_configuration": {
    //         "max_cache_anchors": 10,
    //         "should_speculate": false,
    //         "min_total_token": 10000
    //       },
    //       "max_output_tokens": 8192,
    //       "default_temperature": null
    //     }
    //   ]
    // },
    "openai": {
      "version": "1",
      "available_models": [
        {
          "provider": "openai",
          "name": "chatgpt-4o-latest",
          "display_name": "chatgpt-4o-latest",
          "max_tokens": 128000,
          "max_output_tokens": 16384
        }
      ]
    },
    "ollama": {
      "low_speed_timeout_in_seconds": 600,
      "available_models": [
        {
          "provider": "ollama",
          "name": "qwen2.5-coder",
          "display_name": "qwen2.5-coder-128k",
          "max_tokens": 128000,
          "max_output_tokens": 8192
        }
      ]
    }
  }
}
