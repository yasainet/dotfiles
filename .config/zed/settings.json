{
  // vim
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },
  // theme
  "theme": {
    "mode": "dark",
    "light": "Nord",
    "dark": "Nord"
  },
  // theme override
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        // "font_style": "italic"
      }
    }
  },
  // syntax highlighting
  "file_types": {
    "Shell Script": [".env.*"]
  },
  // outline_panel
  "outline_panel": {
    "button": false
  },
  // ui
  "ui_font_size": 14,
  "chat_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false
  },
  "tabs": {
    "git_status": true
  },
  "project_panel": {
    "auto_fold_dirs": false
  },
  // editor
  "buffer_font_size": 14,
  "current_line_highlight": "none",
  "scrollbar": {
    "show": "auto",
    "cursors": false,
    "git_diff": false
  },
  "vertical_scroll_margin": 0,
  "soft_wrap": "editor_width",
  "journal": {
    "hour_format": "hour24"
  },
  // terminal
  "terminal": {
    "copy_on_select": true,
    "blinking": "on",
    "button": false,
    "env": {
      "EDITOR": "zed --wait"
    }
  },
  // Git
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  // GitHub Copilot
  "show_inline_completions": false,
  // Assistant Panel
  "assistant": {
    "button": false,
    "version": "2",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-sonnet-20240620"
    }
    // "default_width": 640
  }
}
