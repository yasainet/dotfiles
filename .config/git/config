[user]
	name = yasainet
	email = mail@yasainet.com

[color]
	ui = auto

[push]
	default = current

[core]
	ignorecase = false

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[merge]
	commit = no

[pager]
	branch = false
	tag = false

[init]
	defaultBranch = main

[credential "http://localhost:8929"]
	provider = generic

[credential "http://127.0.0.1:8929"]
	provider = generic

[credential "http://127.0.0.1:3030"]
	provider = generic

[credential "http://host.orb.internal:3030"]
	provider = generic

[credential "https://dev.azure.com"]
	useHttpPath = true

[include]
	path = ~/.gitconfig.local
