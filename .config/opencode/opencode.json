{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:latest": {
          "name": "Qwen3.6 (local)",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "ollama/qwen3.6:latest",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}
