# Notifications
desktop-notifications = true

# Shell Integration
shell-integration = none

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Window
window-title-font-family = SF Mono
window-theme = system
window-colorspace = display-p3
window-save-state = always
window-padding-balance = true
macos-titlebar-style = transparent
title = " "
macos-titlebar-proxy-icon = hidden
background-opacity = 0.90
maximize = true

# Theme
theme = TokyoNight Night

# Font
font-family = "Lilex"
font-family = "PlemolJP Console NF"
font-size = 14
bold-is-bright= true
adjust-cell-height = 24%

# Cursor
cursor-style = block
cursor-style-blink = true

# Mouse
mouse-hide-while-typing = true

# Option key as Alt
macos-option-as-alt = left

# Disable defaults
keybind = cmd+shift+p=unbind
keybind = cmd+f=unbind

# ==============================
# Keybindings for Claude Code
# ==============================

keybind = shift+enter=text:\x1b\r

# ==============================
# Keybindings for nvim
# ==============================

# Cmd+f -> search
keybind = cmd+f=text:\x1bf

# Cmd+p -> find files
keybind = cmd+p=text:\x1bp

# Cmd+s -> save
keybind = cmd+s=text:\x1bs

# Cmd+/ -> comment toggle
keybind = cmd+/=text:\x1b/

# Cmd+j -> toggle terminal
keybind = cmd+j=text:\x1bj

# Cmd+Shift+f -> live grep
keybind = cmd+shift+f=text:\x1bF

# Cmd+Shift+e -> explorer
keybind = cmd+shift+e=text:\x1be

# Cmd+Shift+g -> diffview
keybind = cmd+shift+g=text:\x1bG

# ==============================
# Keybindings for tmux
# ==============================

# --- session ---

# Cmd+` / Cmd+Shift+` -> next/previous session
keybind = cmd+grave_accent=unbind
keybind = cmd+grave_accent=text:\x02q
keybind = cmd+shift+grave_accent=unbind
keybind = cmd+shift+grave_accent=text:\x02Q

# --- window ---

# Cmd+t -> new window
keybind = cmd+t=unbind
keybind = cmd+t=text:\x02c

# Cmd+w -> kill window
keybind = cmd+w=unbind
keybind = cmd+w=text:\x02&

# Cmd+1~9 -> select window
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind
keybind = cmd+one=text:\x021
keybind = cmd+two=text:\x022
keybind = cmd+three=text:\x023
keybind = cmd+four=text:\x024
keybind = cmd+five=text:\x025
keybind = cmd+six=text:\x026
keybind = cmd+seven=text:\x027
keybind = cmd+eight=text:\x028
keybind = cmd+nine=text:\x029

# Cmd+Shift+[/] -> previous/next window
keybind = cmd+shift+bracket_left=text:\x02p
keybind = cmd+shift+bracket_right=text:\x02n

# Cmd+b -> copy mode
keybind = cmd+b=text:\x02v

# --- pane ---

# Cmd+d -> split right
keybind = cmd+d=unbind
keybind = cmd+d=text:\x02%

# Cmd+Shift+d -> split down
keybind = cmd+shift+d=unbind
keybind = cmd+shift+d=text:\x02"

# Cmd+[/] -> select pane left/right
keybind = cmd+bracket_left=text:\x08
keybind = cmd+bracket_right=text:\x0c

# Cmd+k -> clear pane history
keybind = cmd+k=text:\x02K
