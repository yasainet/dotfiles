# Notifications
desktop-notifications = true

# Shell Integration
shell-integration = none

# tmux
command = /bin/sh -c '/opt/homebrew/bin/tmux attach || /opt/homebrew/bin/tmux new-session'

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Window
window-title-font-family = SF Mono
window-theme = system
window-colorspace = display-p3
window-save-state = always
window-padding-balance = true
macos-titlebar-style = transparent
title = ""
macos-titlebar-proxy-icon = hidden
background-opacity = 0.9
maximize = true

# Theme
theme = TokyoNight Night

# Font
font-family = "PlemolJP Console NF"
font-size = 15
adjust-cell-height = 25%

# Cursor
cursor-style = block
cursor-style-blink = true

# Mouse
mouse-hide-while-typing = true

# Option key as Alt
macos-option-as-alt = left

# Disable defaults
keybind = cmd+shift+p=unbind

# ==============================
# Keybindings for Claude Code
# ==============================

keybind = shift+enter=text:\x1b\r

# ==============================
# Keybindings for tmux
# ==============================

# --- window ---

# Cmd+t -> new window
keybind = cmd+t=unbind
keybind = cmd+t=text:\x1bbc

# Cmd+w -> kill window
keybind = cmd+w=unbind
keybind = cmd+w=text:\x1bb&

# Cmd+1~9 -> select window
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind
keybind = cmd+one=text:\x1bb1
keybind = cmd+two=text:\x1bb2
keybind = cmd+three=text:\x1bb3
keybind = cmd+four=text:\x1bb4
keybind = cmd+five=text:\x1bb5
keybind = cmd+six=text:\x1bb6
keybind = cmd+seven=text:\x1bb7
keybind = cmd+eight=text:\x1bb8
keybind = cmd+nine=text:\x1bb9

# Cmd+Shift+[/] -> previous/next window
keybind = cmd+shift+bracket_left=text:\x1bbp
keybind = cmd+shift+bracket_right=text:\x1bbn

# Cmd+b -> copy mode
keybind = cmd+b=text:\x1bbv

# --- pane ---

# Cmd+d -> split right
keybind = cmd+d=unbind
keybind = cmd+d=text:\x1bb%

# Cmd+Shift+d -> split down
keybind = cmd+shift+d=unbind
keybind = cmd+shift+d=text:\x1bb"

# Cmd+k -> clear pane history
keybind = cmd+k=text:\x1bbK
