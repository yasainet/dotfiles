# theme
theme = catppuccin-mocha
background-opacity = 0.85

# font
font-family = BlexMono Nerd Font Mono
font-size = 14

# cursor
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor

# window
window-padding-balance = true
window-save-state = always
window-height = 9999
window-width = 9999
