# Notifications
desktop-notifications = true

# Shell Integration
shell-integration = none

# tmux
command = /bin/sh -c '/opt/homebrew/bin/tmux attach || /opt/homebrew/bin/tmux new-session'

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Window
window-title-font-family = SF Mono
window-theme = system
window-colorspace = display-p3
window-save-state = always
window-padding-balance = true
macos-titlebar-style = transparent
title = " "
macos-titlebar-proxy-icon = hidden
background-opacity = 0.95
maximize = true

# Theme
theme = TokyoNight Night

# Font
font-family = "UDEV Gothic NFLG"
font-size = 14
bold-is-bright= true
adjust-cell-height = 20%

# Cursor
cursor-style = block
cursor-style-blink = true

# Mouse
mouse-hide-while-typing = true

# Option key as Alt
macos-option-as-alt = left

# Disable defaults
keybind = cmd+shift+p=unbind

# ==============================
# Keybindings for Claude Code
# ==============================

keybind = shift+enter=text:\x1b\r

# ==============================
# Keybindings for nvim
# ==============================

# Cmd+j -> toggle terminal
keybind = cmd+j=text:\x1bj

# ==============================
# Keybindings for tmux
# ==============================

# --- window ---

# Cmd+t -> new window
keybind = cmd+t=unbind
keybind = cmd+t=text:\x00c

# Cmd+w -> kill window
keybind = cmd+w=unbind
keybind = cmd+w=text:\x00&

# Cmd+1~9 -> select window
keybind = cmd+digit_1=unbind
keybind = cmd+digit_2=unbind
keybind = cmd+digit_3=unbind
keybind = cmd+digit_4=unbind
keybind = cmd+digit_5=unbind
keybind = cmd+digit_6=unbind
keybind = cmd+digit_7=unbind
keybind = cmd+digit_8=unbind
keybind = cmd+digit_9=unbind
keybind = cmd+one=text:\x001
keybind = cmd+two=text:\x002
keybind = cmd+three=text:\x003
keybind = cmd+four=text:\x004
keybind = cmd+five=text:\x005
keybind = cmd+six=text:\x006
keybind = cmd+seven=text:\x007
keybind = cmd+eight=text:\x008
keybind = cmd+nine=text:\x009

# Cmd+Shift+[/] -> previous/next window
keybind = cmd+shift+bracket_left=text:\x00p
keybind = cmd+shift+bracket_right=text:\x00n

# Cmd+b -> copy mode
keybind = cmd+b=text:\x00v

# --- pane ---

# Cmd+d -> split right
keybind = cmd+d=unbind
keybind = cmd+d=text:\x00%

# Cmd+Shift+d -> split down
keybind = cmd+shift+d=unbind
keybind = cmd+shift+d=text:\x00"

# Cmd+[/] -> select pane left/right
# keybind = cmd+bracket_left=text:\x08
# keybind = cmd+bracket_right=text:\x0c

# Cmd+k -> clear pane history
keybind = cmd+k=text:\x00K
